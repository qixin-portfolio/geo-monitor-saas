# Copy this file to .env on the production server.
# Do not commit real secrets.

# Public app URL
NEXT_PUBLIC_APP_URL=https://geoup.online

# Clerk production keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Stripe test mode first; switch to live keys only after real billing is ready.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_STRIPE_AGENCY_PRICE_ID=

# Docker images and ports
POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:16-alpine
BASE_IMAGE=docker.m.daocloud.io/library/node:20-alpine
POSTGRES_DB=geo_monitor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-long-random-password
APP_PORT=3000
POSTGRES_PORT=5432
