# Copy this file to .env on the production server.
# Do not commit real secrets.

# Public app URL - replace with your production domain.
NEXT_PUBLIC_APP_URL=https://example.com

# Clerk production keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=__CLERK_PUBLISHABLE_KEY__
CLERK_SECRET_KEY=__CLERK_SECRET_KEY__
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Stripe test mode first; switch to live keys only after real billing is ready.
STRIPE_SECRET_KEY=__STRIPE_SECRET_KEY__
STRIPE_WEBHOOK_SECRET=__STRIPE_WEBHOOK_SECRET__
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=__STRIPE_STARTER_PRICE_ID__
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=__STRIPE_PRO_PRICE_ID__
NEXT_PUBLIC_STRIPE_AGENCY_PRICE_ID=__STRIPE_AGENCY_PRICE_ID__

# Automated monitoring
MONITORING_PROVIDER=openai
OPENAI_API_KEY=__OPENAI_API_KEY__
DEEPSEEK_API_KEY=__DEEPSEEK_API_KEY__
ARK_API_KEY=__ARK_API_KEY__
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
MONITORING_MODEL=gpt-4o-mini
MONITORING_TIMEOUT_MS=45000
MONITORING_MAX_TOKENS=900
# Vercel Cron sends Authorization: Bearer $CRON_SECRET.
CRON_SECRET=__CHANGE_ME_RANDOM_STRING__
# Local/manual cron checks can still use x-monitoring-cron-secret.
MONITORING_CRON_SECRET=__CHANGE_ME_RANDOM_STRING__

# Docker images and ports
POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:16-alpine
BASE_IMAGE=docker.m.daocloud.io/library/node:20-alpine
POSTGRES_DB=geo_monitor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__CHANGE_ME_LONG_RANDOM_PASSWORD__
APP_PORT=3000
POSTGRES_PORT=5432
