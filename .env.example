# App
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Database - replace placeholders with your local or production database values.
DATABASE_URL="postgresql://__POSTGRES_USER__:__POSTGRES_PASSWORD__@localhost:5432/geo_monitor?schema=public"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Stripe test mode
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_STRIPE_AGENCY_PRICE_ID=

# Monitoring
# Provider: "openai", "deepseek", or "ark"
MONITORING_PROVIDER=openai
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
MONITORING_MODEL=
MONITORING_TIMEOUT_MS=45000
MONITORING_MAX_TOKENS=900
# Vercel Cron sends Authorization: Bearer $CRON_SECRET.
CRON_SECRET=__CHANGE_ME_RANDOM_STRING__
# Local/manual cron checks can still use x-monitoring-cron-secret.
MONITORING_CRON_SECRET=__CHANGE_ME_RANDOM_STRING__

# Docker
POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:16-alpine
BASE_IMAGE=docker.m.daocloud.io/library/node:20-alpine
POSTGRES_DB=geo_monitor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
APP_PORT=3000
POSTGRES_PORT=5432
